# Multi Model Agents 环境变量模板
# 复制本文件为 .env，然后只在 .env 中填写真实值。
# 不要把真实 API key 写入这个示例文件。

# Coder 角色：Anthropic / Claude / Opus-compatible endpoint
ANTHROPIC_API_KEY=
MMA_CODER_PROVIDER=anthropic
MMA_CODER_MODEL=claude-opus-4-8
MMA_CODER_API_KEY_ENV=ANTHROPIC_API_KEY
MMA_CODER_BASE_URL=https://api.anthropic.com

# Reviewer 角色：默认使用 Codex 内部审查，不需要额外 OpenAI API key。
OPENAI_API_KEY=
MMA_REVIEWER_PROVIDER=codex-internal
MMA_REVIEWER_MODEL=gpt-5.5
MMA_REVIEWER_API_KEY_ENV=
MMA_REVIEWER_BASE_URL=

# Tester 角色：Gemini endpoint
GEMINI_API_KEY=
MMA_TESTER_PROVIDER=gemini
MMA_TESTER_MODEL=gemini-3.5-flash
MMA_TESTER_API_KEY_ENV=GEMINI_API_KEY
MMA_TESTER_BASE_URL=https://generativelanguage.googleapis.com
MMA_GEMINI_API_KEY_IN_HEADER=true

# 可选 custom 角色：OpenAI-compatible gateway、LiteLLM、OpenRouter、本地代理等。
EXTERNAL_MODEL_API_KEY=
MMA_CUSTOM_PROVIDER=openai-compatible
MMA_CUSTOM_MODEL=gpt-5.5
MMA_CUSTOM_API_KEY_ENV=EXTERNAL_MODEL_API_KEY
MMA_CUSTOM_BASE_URL=https://api.openai.com/v1

# 外部模型 HTTP 调用超时时间，单位毫秒。
MMA_HTTP_TIMEOUT_MS=120000
MMA_HTTP_MAX_ATTEMPTS=3
MMA_HTTP_RETRY_BASE_DELAY_MS=500
MMA_MODEL_STREAMING=true
MMA_MCP_PROGRESS_NOTIFICATIONS=true
MMA_WORKSPACE_EDIT_RETURN_FILE_CHARS=6000

# 本地 RAG 知识库。默认留空时使用稳定的 Codex 用户目录：
# $CODEX_HOME/multi-model-agents/rag
# 未设置 CODEX_HOME 时为用户目录下的 .codex/multi-model-agents/rag。
MMA_RAG_ROOT=
MMA_RAG_WRITE_ENABLED=true
MMA_RAG_MAX_RESULT_CHARS=4000
