# AI Agent Swarm Codex-only environment template
# Copy this file to .env only when you need local overrides.
# Do not put real API keys or release tokens in this example file.

# MCP visible progress/log notifications.
MMA_MCP_PROGRESS_NOTIFICATIONS=true

# Workspace text read limit used by RAG ingest.
MMA_WORKSPACE_FILE_CHAR_LIMIT=200000

# Local RAG memory. Leave empty to use the stable Codex user directory:
# $CODEX_HOME/multi-model-agents/rag
# When CODEX_HOME is not set, the fallback is ~/.codex/multi-model-agents/rag.
MMA_RAG_ROOT=
MMA_RAG_WRITE_ENABLED=true
MMA_RAG_MAX_RESULT_CHARS=4000
